# Copiar como .env y completar antes de levantar docker-compose

# App
ENV=local
DEBUG=true

# Base de datos (coincide con docker-compose.yml por defecto)
DATABASE_URL=postgresql+asyncpg://nova:nova@postgres:5432/nova

# Redis / Celery
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# Claude API (Agente Contable / Receptor) - dejar vacío usa clasificación por defecto
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-5

# DIAN (simulada en el MVP)
DIAN_SIMULATED=true
DIAN_MOCK_CSV_PATH=app/services/dian_mock_facturas.csv

# Seguridad - CAMBIAR en cualquier entorno distinto a local
JWT_SECRET=CAMBIA_ESTO_EN_PRODUCCION
